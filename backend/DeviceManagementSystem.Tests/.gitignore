## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# ASP.NET specific
*.dbmdl
*.jfm
*.publishsettings
*.pubxml
*.pubxml.user
*.azurePubxml
*.pfx

# IIS Express
.vs/
.vscode/
.vsconfig
.vspscc

# Visual Studio cache/options
*.VC.db
*.VC.VC.opendb

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet
*.nupkg
*.snupkg
packages/
!packages/build/
*.nuget.props
*.nuget.targets

# .NET Core / ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/
wwwroot/lib/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Rider / ReSharper
_ReSharper*/
*.DotSettings.user

# DotCover
*.dotCover

# StyleCop
StyleCopReport.xml

# Backup & temp files
*.bak
*.tmp
*.temp
*.swp

# SQL Server files
*.mdf
*.ldf

# Publish output
publish/
*.Publish.xml

# Azure
*.azurePubxml

# Generated files
Generated_Code/

# Entity Framework
*.edmx.diagram

# Node (if using frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage reports
coverage/
*.coverage
*.coveragexml